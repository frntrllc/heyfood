          "requires": ["native_microphone", "audio_transcribe_scope_preflight", "memory_only_audio", "typed_fallback"],
          "asserts": ["ctrl_space_and_f8_supported", "elapsed_recording_status_visible", "scope_is_verified_before_microphone_open", "cancel_closes_microphone"]
