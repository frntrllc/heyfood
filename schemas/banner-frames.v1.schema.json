{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hello.food/schemas/banner-frames.v1.schema.json",
  "title": "hey.food banner frame manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "source", "geometry", "frames"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["banner_sha256", "palette_sha256"],
      "properties": {
        "banner_sha256": { "$ref": "#/$defs/sha256" },
        "palette_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "encoding"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "encoding": { "const": "utf-8" }
      }
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/frame" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "start", "length"],
      "properties": {
        "line": { "type": "integer", "minimum": 0 },
        "start": { "type": "integer", "minimum": 0 },
        "length": { "type": "integer", "minimum": 1 }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "duration_ms",
        "visible_lines",
        "accent_spans",
        "plain_text_sha256"
      ],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "visible_lines": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "accent_spans": {
          "type": "array",
          "items": { "$ref": "#/$defs/span" },
          "uniqueItems": true
        },
        "plain_text_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
